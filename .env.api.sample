# Database Configuration
DATABASE_URL=

# Application Environment
NODE_ENV=development
PORT=4000
COMMIT_HASH=v0.0.0

# Logging Configuration
LOG_LEVEL=debug
PRETTY_LOGS=true
LOGS_DESTINATION=/app/logs/out.log

# Authentication & Security
JWT_SECRET=your-jsonwebtoken-secret-key-here
AUTH0_DOMAIN=your-auth0-domain.eu.auth0.com

# Blockchain Configuration
BLOCKCHAIN_RPC_URL=https://your-rpc-url-here
BLOCKCHAIN_PRIVATE_KEY=0x-your-private-key-here
BLOCKCHAIN_CHAIN_ID=1
BLOCKCHAIN_EXPLORER=https://your-blockchain-explorer-url.com

# Smart Contract Addresses
DEALS_MANAGER_CONTRACT_ADDRESS=0x-your-deals-manager-contract-address
INVESTMENT_TOKEN_CONTRACT_ADDRESS=0x-your-investment-token-contract-address
INVESTMENT_TOKEN_SYMBOL=TRU
INVESTMENT_TOKEN_DECIMALS=18

# Deal Configuration
AUTOMATIC_DEALS_ACCEPTANCE=false

# Email Configuration
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_USERNAME=your-email@example.com
EMAIL_PASSWORD=your-email-password
MAIL_TO=support@example.com

# Application Domain
APP_DOMAIN=http://localhost:3000

# Push Notifications (VAPID)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# File Storage (Vercel Blob Storage)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your-token-here

# KYC Configuration (Onfido)
ONFIDO_API_TOKEN=your-onfido-api-token
ONFIDO_WORKFLOW_ID=your-onfido-workflow-id
ONFIDO_WEBHOOK_TOKEN=your-onfido-webhook-token
